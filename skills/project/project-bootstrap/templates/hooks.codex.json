{
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git diff --quiet HEAD || npm run verify || exit 2",
            "timeout": 180
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git diff --quiet HEAD || npm run verify || exit 2",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
