{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --quiet HEAD || npm run verify --silent",
            "timeout": 180000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/docs-reminder.cjs",
            "timeout": 15000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --quiet HEAD || npm run verify --silent",
            "timeout": 180000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/docs-reminder.cjs",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
