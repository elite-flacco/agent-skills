#!/bin/sh
set -e

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/pre-commit.ps1
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/pre-commit.ps1
fi

if command -v powershell >/dev/null 2>&1; then
  exec powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pre-commit.ps1
fi

echo "PowerShell is required to run this repository's pre-commit hook." >&2
exit 1
